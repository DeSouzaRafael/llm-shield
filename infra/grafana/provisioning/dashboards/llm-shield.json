{
  "title": "llm-shield",
  "uid": "llm-shield-main",
  "schemaVersion": 38,
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "Requests/min by decision",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(llm_shield_requests_total[1m]) * 60",
          "legendFormat": "{{decision}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Block rate by guardrail",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(llm_shield_blocks_total[1m]) * 60",
          "legendFormat": "{{guardrail}} ({{pipeline}})"
        }
      ]
    },
    {
      "id": 3,
      "title": "Guardrail latency p95 (ms)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(llm_shield_guardrail_latency_seconds_bucket[5m])) * 1000",
          "legendFormat": "{{guardrail}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "LLM latency p95 (ms)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(llm_shield_llm_latency_seconds_bucket[5m])) * 1000",
          "legendFormat": "p95"
        }
      ]
    }
  ]
}
